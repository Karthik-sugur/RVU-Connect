rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isRvuEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@rvu\\.edu\\.in$');
    }

    function isSuperAdmin() {
      return isRvuEmail()
        && (
          exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid))
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superAdmin'
          )
        );
    }

    function isApprovedClubCore(clubId) {
      return isRvuEmail()
        && exists(/databases/$(database)/documents/clubs/$(clubId)/coreMembers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/clubs/$(clubId)/coreMembers/$(request.auth.token.email)).data.status == 'approved';
    }

    function isApprovedSchoolRep(schoolId) {
      return isRvuEmail()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/representatives/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/representatives/$(request.auth.uid)).data.status == 'approved';
    }

    function isPublished() {
      return resource.data.status == 'published';
    }

    function createsOwnDoc(uid) {
      return request.auth.uid == uid;
    }

    function unchanged(field) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([field]);
    }

    match /users/{uid} {
      allow create: if isRvuEmail()
        && createsOwnDoc(uid)
        && request.resource.data.role == 'student'
        && request.resource.data.email == request.auth.token.email;

      allow read: if isSuperAdmin() || (isRvuEmail() && createsOwnDoc(uid));

      allow update: if isSuperAdmin() || (isRvuEmail()
        && createsOwnDoc(uid)
        && unchanged('role')
        && unchanged('email'));

      allow delete: if isSuperAdmin();

      match /savedItems/{savedId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }

      match /followedClubs/{clubId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }

      match /rsvps/{eventId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }


    }

    match /superAdmins/{adminId} {
      allow read: if isRvuEmail() && adminId == request.auth.uid;
      allow create, update, delete: if isSuperAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if isRvuEmail();
      allow create, update, delete: if isSuperAdmin();
    }

    match /contentReviews/{reviewId} {
      allow create: if isRvuEmail();
      allow read, update, delete: if isSuperAdmin();
    }

    match /schools/{schoolId} {
      allow read: if isRvuEmail();
      allow create, update, delete: if isSuperAdmin();

      match /representatives/{uid} {
        allow read: if isSuperAdmin() || createsOwnDoc(uid) || isApprovedSchoolRep(schoolId);
        allow create, update, delete: if isSuperAdmin();
      }
    }

    match /clubs/{clubId} {
      allow read: if isRvuEmail() && (resource.data.status == 'approved' || isSuperAdmin() || isApprovedClubCore(clubId));
      allow create, delete: if isSuperAdmin();

      allow update: if isSuperAdmin() || (isApprovedClubCore(clubId) && unchanged('createdAt') && unchanged('createdBy'));

      match /coreMembers/{memberEmail} {
        allow read: if isSuperAdmin()
          || (isRvuEmail() && memberEmail == request.auth.token.email)
          || isApprovedClubCore(clubId);

        // Super admin can always write. Approved core members can create/update
        // their own club's core (e.g. approving a club application via batch write).
        allow create, update: if isSuperAdmin() || isApprovedClubCore(clubId);
        allow delete: if isSuperAdmin();
      }
    }

    match /clubApplications/{applicationId} {
      // Students can create their own pending application
      allow create: if isRvuEmail()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'pending';

      // Student reads their own; club core reads for their club; super admin reads all
      allow read: if isSuperAdmin()
        || (isRvuEmail() && resource.data.uid == request.auth.uid)
        || isApprovedClubCore(resource.data.clubId);

      // Student can withdraw their own pending application
      // Club core and super admin can approve or reject
      allow update: if isSuperAdmin()
        || (isRvuEmail()
            && resource.data.uid == request.auth.uid
            && request.resource.data.status == 'withdrawn'
            && resource.data.status == 'pending')
        || isApprovedClubCore(resource.data.clubId);

      // Only super admin can delete (preserve records)
      allow delete: if isSuperAdmin();
    }

    match /events/{eventId} {
      allow read: if isRvuEmail() && (isPublished() || isSuperAdmin());

      allow create: if isRvuEmail()
        && (
          (request.resource.data.hostType == 'club' && isApprovedClubCore(request.resource.data.clubId))
          || (request.resource.data.hostType == 'school' && isApprovedSchoolRep(request.resource.data.schoolId))
          || isSuperAdmin()
        );

      allow update: if isSuperAdmin()
        || (resource.data.hostType == 'club' && isApprovedClubCore(resource.data.clubId) && unchanged('createdAt'))
        || (resource.data.hostType == 'school' && isApprovedSchoolRep(resource.data.schoolId) && unchanged('createdAt'));
        
      allow delete: if isSuperAdmin()
        || (resource.data.hostType == 'club' && isApprovedClubCore(resource.data.clubId))
        || (resource.data.hostType == 'school' && isApprovedSchoolRep(resource.data.schoolId));

      match /rsvps/{uid} {
        allow read: if isSuperAdmin() || createsOwnDoc(uid);
        allow create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }
    }

    match /announcements/{announcementId} {
      allow read: if isRvuEmail() && (isPublished() || isSuperAdmin());

      allow create: if isRvuEmail()
        && (
          (request.resource.data.sourceType == 'club' && isApprovedClubCore(request.resource.data.clubId))
          || (request.resource.data.sourceType == 'school' && isApprovedSchoolRep(request.resource.data.schoolId))
          || isSuperAdmin()
        );

      allow update: if isSuperAdmin()
        || (resource.data.sourceType == 'club' && isApprovedClubCore(resource.data.clubId) && unchanged('createdAt'))
        || (resource.data.sourceType == 'school' && isApprovedSchoolRep(resource.data.schoolId) && unchanged('createdAt'));
        
      allow delete: if isSuperAdmin()
        || (resource.data.sourceType == 'club' && isApprovedClubCore(resource.data.clubId))
        || (resource.data.sourceType == 'school' && isApprovedSchoolRep(resource.data.schoolId));
    }

    match /projects/{projectId} {
      allow read: if isRvuEmail();

      allow create: if isRvuEmail()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status in ['open', 'closed'];

      allow update: if isSuperAdmin()
        || (isRvuEmail() && resource.data.ownerId == request.auth.uid && unchanged('ownerId') && unchanged('createdAt'));
        
      allow delete: if isSuperAdmin()
        || (isRvuEmail() && resource.data.ownerId == request.auth.uid);
    }

    match /hostRequests/{requestId} {
      allow create: if isRvuEmail()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['clubCore', 'schoolRepresentative', 'newClub'];

      allow read: if isSuperAdmin()
        || (isRvuEmail() && resource.data.uid == request.auth.uid);

      allow update, delete: if isSuperAdmin();
    }

    match /moderationFlags/{flagId} {
      allow create: if isRvuEmail();
      allow read, update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
