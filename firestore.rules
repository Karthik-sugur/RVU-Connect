rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isRvuEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@rvu\\.edu\\.in$');
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myUserDoc() {
      return userDoc(request.auth.uid);
    }

    function myRole() {
      return myUserDoc().data.role;
    }

    function isSuperAdmin() {
      return isRvuEmail()
        && (
          myRole() == 'superAdmin'
          || exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid))
          || exists(/databases/$(database)/documents/superAdmins/$(request.auth.token.email))
        );
    }

    function isApprovedClubCore(clubId) {
      return isRvuEmail()
        && exists(/databases/$(database)/documents/clubs/$(clubId)/coreMembers/$(request.auth.token.email))
        && get(/databases/$(database)/documents/clubs/$(clubId)/coreMembers/$(request.auth.token.email)).data.status == 'approved';
    }

    function isClubPresident(clubId) {
      return isApprovedClubCore(clubId)
        && get(/databases/$(database)/documents/clubs/$(clubId)/coreMembers/$(request.auth.token.email)).data.role in ['president', 'owner'];
    }

    function isApprovedSchoolRep(schoolId) {
      return isRvuEmail()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/representatives/$(request.auth.uid))
        && get(/databases/$(database)/documents/schools/$(schoolId)/representatives/$(request.auth.uid)).data.status == 'approved';
    }

    function isPublished() {
      return resource.data.status == 'published';
    }

    function createsOwnDoc(uid) {
      return request.auth.uid == uid;
    }

    match /users/{uid} {
      allow create: if isRvuEmail()
        && createsOwnDoc(uid)
        && request.resource.data.role == 'student'
        && request.resource.data.email == request.auth.token.email;

      allow read: if isSuperAdmin() || (isRvuEmail() && createsOwnDoc(uid));

      allow update: if isRvuEmail()
        && createsOwnDoc(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['name', 'school', 'year', 'interests', 'onboardingComplete', 'clubIds', 'updatedAt']);

      allow update, delete: if isSuperAdmin();

      match /savedItems/{savedId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }

      match /followedClubs/{clubId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }

      match /rsvps/{eventId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }

      match /applications/{projectId} {
        allow read, create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
        allow read, update: if isSuperAdmin();
      }
    }

    match /superAdmins/{adminId} {
      allow read: if isRvuEmail()
        && (adminId == request.auth.uid || adminId == request.auth.token.email);
      allow create, update, delete: if isSuperAdmin();
    }

    match /siteSettings/{settingId} {
      allow read: if isRvuEmail();
      allow create, update, delete: if isSuperAdmin();
    }

    match /auditLogs/{logId} {
      allow create, read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /contentReviews/{reviewId} {
      allow create: if isRvuEmail();
      allow read, update, delete: if isSuperAdmin();
    }

    match /schools/{schoolId} {
      allow read: if isRvuEmail();
      allow create, update, delete: if isSuperAdmin();

      match /representatives/{uid} {
        allow read: if isSuperAdmin() || createsOwnDoc(uid) || isApprovedSchoolRep(schoolId);

        allow create: if isRvuEmail()
          && createsOwnDoc(uid)
          && request.resource.data.status == 'pending'
          && request.resource.data.email == request.auth.token.email;

        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
      }
    }

    match /clubs/{clubId} {
      allow read: if isRvuEmail() && (resource.data.status == 'approved' || isSuperAdmin() || isApprovedClubCore(clubId));
      allow create, update, delete: if isSuperAdmin();

      allow update: if isApprovedClubCore(clubId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['description', 'doing', 'highlights', 'joinLink', 'registrationOpen', 'updatedAt']);

      allow update: if isClubPresident(clubId)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'description',
            'doing',
            'highlights',
            'joinLink',
            'registrationOpen',
            'currentPresidentName',
            'currentPresidentEmail',
            'facultyAdvisorName',
            'facultyAdvisorEmail',
            'updatedAt'
          ]);

      match /coreMembers/{memberEmail} {
        allow read: if isSuperAdmin()
          || (isRvuEmail() && memberEmail == request.auth.token.email)
          || isApprovedClubCore(clubId);

        allow create: if isSuperAdmin()
          || (
            isClubPresident(clubId)
            && request.resource.data.permanent != true
          )
          || (
            isRvuEmail()
            && memberEmail == request.auth.token.email
            && request.resource.data.status == 'pending'
            && request.resource.data.email == request.auth.token.email
          );

        allow update: if isSuperAdmin()
          || (
            isClubPresident(clubId)
            && resource.data.permanent != true
            && request.resource.data.permanent != true
          );
        allow delete: if isSuperAdmin()
          || (isClubPresident(clubId) && resource.data.permanent != true);
      }
    }

    match /events/{eventId} {
      allow read: if isRvuEmail() && (isPublished() || isSuperAdmin());

      allow create: if isRvuEmail()
        && (
          (request.resource.data.hostType == 'club'
            && isApprovedClubCore(request.resource.data.clubId))
          ||
          (request.resource.data.hostType == 'school'
            && isApprovedSchoolRep(request.resource.data.schoolId))
          ||
          isSuperAdmin()
        );

      allow update, delete: if isSuperAdmin()
        || (resource.data.hostType == 'club' && isApprovedClubCore(resource.data.clubId))
        || (resource.data.hostType == 'school' && isApprovedSchoolRep(resource.data.schoolId));

      match /rsvps/{uid} {
        allow read: if isSuperAdmin() || createsOwnDoc(uid);
        allow create, update, delete: if isRvuEmail() && createsOwnDoc(uid);
      }
    }

    match /announcements/{announcementId} {
      allow read: if isRvuEmail() && (isPublished() || isSuperAdmin());

      allow create: if isRvuEmail()
        && (
          (request.resource.data.sourceType == 'club'
            && isApprovedClubCore(request.resource.data.clubId))
          ||
          (request.resource.data.sourceType == 'school'
            && isApprovedSchoolRep(request.resource.data.schoolId))
          ||
          isSuperAdmin()
        );

      allow update, delete: if isSuperAdmin()
        || (resource.data.sourceType == 'club' && isApprovedClubCore(resource.data.clubId))
        || (resource.data.sourceType == 'school' && isApprovedSchoolRep(resource.data.schoolId));
    }

    match /projects/{projectId} {
      allow read: if isRvuEmail();

      allow create: if isRvuEmail()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.status in ['open', 'closed'];

      allow update, delete: if isSuperAdmin()
        || (isRvuEmail() && resource.data.ownerId == request.auth.uid);

      match /applications/{uid} {
        allow read: if isSuperAdmin()
          || createsOwnDoc(uid)
          || get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;

        allow create: if isRvuEmail()
          && createsOwnDoc(uid)
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if isSuperAdmin()
          || get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
          || createsOwnDoc(uid);
      }
    }

    match /hostRequests/{requestId} {
      allow create: if isRvuEmail()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['clubCore', 'schoolRepresentative'];

      allow read: if isSuperAdmin()
        || (isRvuEmail() && resource.data.uid == request.auth.uid);

      allow update, delete: if isSuperAdmin();
    }

    match /moderationFlags/{flagId} {
      allow create: if isRvuEmail();
      allow read, update, delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
